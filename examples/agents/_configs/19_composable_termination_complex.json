{
  "external": false,
  "instructions": "Research and provide a comprehensive answer.",
  "maxTurns": 25,
  "model": "anthropic/claude-sonnet-4-6",
  "name": "complex_agent",
  "termination": {
    "conditions": [
      {
        "stopMessage": "TERMINATE",
        "type": "stop_message"
      },
      {
        "conditions": [
          {
            "caseSensitive": false,
            "text": "DONE",
            "type": "text_mention"
          },
          {
            "maxMessages": 10,
            "type": "max_message"
          }
        ],
        "type": "and"
      },
      {
        "maxTotalTokens": 50000,
        "type": "token_usage"
      }
    ],
    "type": "or"
  },
  "timeoutSeconds": 0,
  "tools": [
    {
      "description": "Search for information.",
      "inputSchema": {
        "properties": {
          "query": {
            "type": "string"
          }
        },
        "required": [
          "query"
        ],
        "type": "object"
      },
      "name": "search",
      "outputSchema": {
        "type": "string"
      },
      "toolType": "worker"
    }
  ]
}